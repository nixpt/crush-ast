          "value": { "type": "StringLiteral", "value": "connected" },
          "meta": {}
        }
      ],
      "meta": {
        "description": "MCPImport: connects to the server (mcp.connect cap), stores the handle under alias, then binds each listed tool by name (mcp.get_tool cap). Requires the mcp.client capability."
