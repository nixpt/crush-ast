struct Point { x, y }

let p = Point { x: 10, y: 20 };

let result = match p {
    Point { x: 10, y: 20 } => "exact match",
    Point { x: 10, y: _ } => "partial x match",
    _ => "no match"
};

print(result);

let n = 10;
match n {
    10 => print("ten"),
    20 => print("twenty"),
    _ => print("other")
}
