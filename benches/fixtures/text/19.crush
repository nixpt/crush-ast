fn calc01(a: Int, b: Int) { return a + b }
fn calc02(a: Int, b: Int) { return a * 2 + b }
fn calc03(a: Int, b: Int) { return a * 3 + b * 2 }
fn calc04(a: Int, b: Int) { return a * 4 - b }
fn calc05(a: Int, b: Int) { return a * 5 + b * 5 }

fn main() {
    let a = 8 + 3
    let b = 2 + 9
    let c = a * 4 - b
    return c
}
